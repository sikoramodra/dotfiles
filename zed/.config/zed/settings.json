{
  "cli_default_open_behavior": "new_window",
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "zed",
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "default": "confirm",
          "always_allow": [
            { "pattern": "^(ls|pwd|echo)\\b" },
            { "pattern": "^(find|grep|rg|ag)\\b" },
            { "pattern": "^(head|tail|cat|less|wc)\\b" },
            { "pattern": "^git\\s+(status|log|diff|branch|show|ls-files)" },
            // TODO: personalize
            { "pattern": "^cargo\\s+(build|test|check|clippy|fmt|run)" },
            { "pattern": "^npm\\s+(install|test|run|build|start)" },
            { "pattern": "^(python|python3|pip|pip3|uv|poetry)\\s" },
            { "pattern": "^(go\\s+(build|test|run|mod))" },
            { "pattern": "^(make|cmake|ninja)\\b" },
            { "pattern": "^(tsc|eslint|prettier|black|ruff)\\b" },
          ],
          "always_deny": [
            { "pattern": "rm\\s+-rf" },
            { "pattern": "sudo\\s" },
            { "pattern": ":\\!\\s*(rm|dd|mkfs|format)" },
            { "pattern": "curl\\s+.*\\|\\s*(sh|bash|zsh)" },
          ],
          "always_confirm": [
            { "pattern": "sudo" },
            { "pattern": "(curl|wget)\\s" },
            { "pattern": "dd\\b" },
          ],
        },
        "edit_file": {
          "default": "confirm",
          "always_deny": [
            { "pattern": "\\.env" },
            { "pattern": "\\.(pem|key|ppk|cert)$" },
            { "pattern": "secrets?/" },
          ],
        },
        "search_web": { "default": "allow" },
        "fetch": { "default": "confirm" },
      },
    },
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium",
    },
    "dock": "right",
    "enabled": true,
    "button": true,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  // "relative_line_numbers": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "local": "standard"
      },
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--issues-exit-code=1",
        ],
      },
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "astro": "html"
          // "svelte": "html"
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class:list=\"{([^}]*)}\"",
            "class:list='{([^}]*)}'"
            // "class=\"([^\"]*)\"",
            //  "class='([^']*)'",
            //  "class:\\s*([^\\s{]+)",
            //  "\\{\\s*class:\\s*\"([^\"]*)\"",
            //  "\\{\\s*class:\\s*'([^']*)'"
          ]
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 80,
        },
      },
    },
  },
  "journal": {
    "hour_format": "hour24",
  },
  "cursor_blink": false,
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "buffer_line_height": { "custom": 1.5 },
  "buffer_font_family": "Source Code Pro",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "scrollbar": {
    "cursors": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "activate_on_close": "left_neighbour",
  },
  "format_on_save": "on",
  "wrap_guides": [80, 100],
  "tab_size": 2,
  "languages": {
    "Shell Script": {
      "language_servers": ["bash-language-server"],
      "formatter": "language_server",
    },
    "Lua": {
      "language_servers": ["lua-language-server"],
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [
            "--syntax=Lua54",
            "--respect-ignores",
            "--stdin-filepath",
            "{buffer_path}",
            "-",
          ],
        },
      },
    },
    "HTML": {
      "language_servers": ["vscode-html-language-server", "biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "CSS": {
      "language_servers": [
        "vscode-css-language-server",
        "biome",
        "tailwindcss-language-server",
        // "unocss-language-server",
      ],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "JavaScript": {
      "language_servers": ["vtsls", "biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TypeScript": {
      "language_servers": ["vtsls", "biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "JSON": {
      "language_servers": ["json-language-server", "biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "JSONC": {
      "language_servers": ["json-language-server", "biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "Astro": {
      "language_servers": [
        "astro-language-server",
        "biome",
        "tailwindcss-language-server",
        // "unocss-language-server",
      ],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "Svelte": {
      "language_servers": [
        "svelte-language-server",
        "biome",
        "tailwindcss-language-server",
        // "unocss-language-server",
      ],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "YAML": {
      "language_servers": ["yaml-language-server"],
      "formatter": {
        "external": {
          "command": "yamlfmt",
          "arguments": [
            "-in",
            "-formatter",
            "retain_line_breaks_single=true"
          ]
        }
      }
    },
    "SQL": {
      "tab_size": 4,
      // "language_servers": ["postgres-language-server"],
      "formatter": {
        "external": {
          "command": "pg_format",
          "arguments": ["-"]
        }
      }
    },
    "Go": {
      "tab_size": 4,
      "language_servers": ["gopls", "golangci-lint"],
      "formatter": {
        "language_server": {
          "name": "gopls"
        },
      },
    },
    "Python": {
      "tab_size": 4,
      "language_servers": ["ty", "ruff"],
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true
      }
    },
    "C++": {
      "tab_size": 4,
    },
    "CMake": {
      "tab_size": 4,
    },
    "QML": {
      "tab_size": 4,
    },
    "XML": {
      "tab_size": 4,
    },
  },
  "autosave": "on_focus_change",
  "autoscroll_on_clicks": true,
  "restore_on_startup": "launchpad",
  "auto_update": false,
  "auto_install_extensions": {
    "basher": true,
    "lua": true,
    "html": true,
    "biome": true,
    "astro": true,
    "svelte": true,
    "unocss": true,
    "docker-compose": true,
    "dockerfile": true,
    "nginx": true,
    "sql": true,
    // "postgres-language-server": true,
    "golangci-lint": true,
    "make": true,
    "fish": true,
    "neocmake": true,
    "qml": true,
    "xml": true,
    "toml": true,
    "env": true,
    "csv": true,
    "rainbow-csv": true,
    "log": true,
    "git-firefly": true,
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
    "line_height": "standard",
  },
}
